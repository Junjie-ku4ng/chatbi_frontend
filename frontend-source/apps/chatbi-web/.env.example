NEXT_PUBLIC_PA_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_MODE=dev_headers
NEXT_PUBLIC_STREAM_ENABLED=true
NEXT_PUBLIC_DEV_USER_ID=web-user
NEXT_PUBLIC_DEV_ROLES=allow:model:*,allow:write:model:*,allow:cube:*,allow:indicator:*,allow:dimension:*
NEXT_PUBLIC_DEV_TENANT=local
NEXT_PUBLIC_ASK_ANALYSIS_V2=false
NEXT_PUBLIC_ASK_ANALYSIS_V2_ALLOWLIST=
NEXT_PUBLIC_INDICATOR_OPS_V2=false
NEXT_PUBLIC_INDICATOR_OPS_V2_ALLOWLIST=
NEXT_PUBLIC_GOVERNANCE_HUB=false
NEXT_PUBLIC_GOVERNANCE_HUB_ALLOWLIST=
NEXT_PUBLIC_GOVERNANCE_HUB_ACTIONS=false
NEXT_PUBLIC_SEMANTIC_SYNC_V1=false
NEXT_PUBLIC_SEMANTIC_SYNC_ALLOWLIST=
NEXT_PUBLIC_ASK_MODEL_ALLOWLIST=
NEXT_PUBLIC_ASK_INCLUDE_TEST_MODELS=false
NEXT_PUBLIC_ASK_EXCLUDE_MODEL_PATTERNS=mock,demo,sample,示例,sandbox,fake,dummy
NEXT_PUBLIC_ASK_REQUIRE_RUNTIME_CHATBI=true
NEXT_PUBLIC_ASK_REQUIRE_QUERY_CAPABLE=false
NEXT_PUBLIC_ASK_REQUIRE_EMBEDDING_AWARE=false
NEXT_PUBLIC_ASK_MODEL_SOURCE_FILTER=

# bearer mode (production/default secure path)
PA_WEB_AUTH_CLIENT_ID=
PA_WEB_AUTH_CLIENT_SECRET=
PA_WEB_AUTH_SCOPE=
PA_WEB_AUTH_COOKIE_SECRET=
PA_WEB_AUTH_SESSION_TTL_SECONDS=3600
PA_WEB_AUTH_REFRESH_CONTEXT_TTL_SECONDS=604800
PA_WEB_AUTH_ALLOW_DYNAMIC_CREDENTIALS=false
