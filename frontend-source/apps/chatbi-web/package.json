    "@tanstack/react-virtual": "^3.13.12",
    "@xyflow/react": "^12.3.6",
    "antd": "^5.27.6",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.2",
    "next": "^16.1.6",
    "re-resizable": "^6.11.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
