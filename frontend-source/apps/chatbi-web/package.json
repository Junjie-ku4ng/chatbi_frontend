  "private": true,
  "scripts": {
    "dev": "next dev -p 3300",
    "build": "next build",
    "start": "next start -p 3300",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "yarn e2e:full",
    "e2e:smoke": "playwright test e2e/smoke.spec.ts e2e/ask-stream-real.spec.ts e2e/route-alias-dual-cycle.spec.ts",
    "e2e:full": "playwright test",
    "e2e:visual": "playwright test e2e/visual-regression.spec.ts",
    "e2e:perf": "playwright test e2e/indicator-ops-perf.spec.ts e2e/ask-analysis-perf.spec.ts e2e/governance-worklist-perf.spec.ts",
    "e2e:cross-browser": "PW_CROSS_BROWSER=true playwright test e2e/smoke.spec.ts e2e/ask-stream-real.spec.ts e2e/route-alias-dual-cycle.spec.ts",
    "test:a11y": "playwright test e2e/a11y.spec.ts",
    "lhci": "lhci autorun --config=.lighthouserc.json"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.24.0",
