{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@opal/*": ["../../vendor/onyx-foss/web/lib/opal/src/*"],
      "@metad/contracts": ["../../packages/contracts/src/index.ts"],
      "@metad/contracts/analytics/semantic-model": ["../../packages/contracts/src/analytics/semantic-model.ts"],
      "@metad/store": ["../../packages/store/src/index.ts"],
      "@metad/ocap-core": ["../../packages/core/src/index.ts"],
      "@metad/ocap-echarts": ["../../packages/echarts/src/index.ts"],
      "@metad/ocap-sql": ["../../packages/sql/src/index.ts"],
      "@metad/ocap-xmla": ["../../packages/xmla/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", ".next/dev/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "src/modules/chat/components/answer-components/analytical-card-preview.tsx",
    "src/modules/chat/components/answer-components/analytical-card-runtime-models.ts",
    "src/modules/chat/components/answer-components/analytical-card-runtime-resolver.ts",
    "src/modules/chat/components/answer-components/analytical-card-runtime-server-agent.ts",
    "src/modules/chat/components/answer-components/analytical-card-runtime-xmla-data-source.ts",
    "src/modules/chat/components/answer-components/analytical-card-runtime-xmla-entity-service.ts",
    "src/modules/chat/components/answer-components/react-*.tsx",
    "src/modules/chat/components/answer-components/use-analytical-card-state.ts",
    "src/modules/chat/components/answer-components/use-base-slicers.ts",
    "src/modules/chat/components/answer-components/use-smart-echart-engine.ts",
    "src/modules/chat/components/answer-components/xpert-slicer-date-variables.ts"
  ]
}
